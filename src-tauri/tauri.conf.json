{
  "$schema": "https://raw.githubusercontent.com/nickknapton12/tauri-docs/refs/heads/v2/src/content/docs/_schema/config.schema.json",
  "productName": "BizSync",
  "version": "1.0.0",
  "identifier": "com.bizsync.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BizSync - 企业级智能办公助手",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend/*": "backend/",
      "../backend/routers/*": "backend/routers/",
      "../utils/*": "utils/",
      "../config.py": "config.py",
      "../main_prompts.py": "main_prompts.py",
      "../create_logger.py": "create_logger.py",
      "../app.py": "app.py",
      "../__init__.py": "__init__.py",
      "../bizsync-backend": "bizsync-backend"
    },
    "targets": ["dmg", "nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "SimpChinese"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
